# Copy this file to `.env` and fill in any values you need to override.
# The `.env` file is git-ignored, so secrets never end up in version control.
#
# How to load the file (PowerShell):
#   Get-Content .env | ForEach-Object {
#     if ($_ -match '^\s*([^#=]+)=(.*)$') {
#       [Environment]::SetEnvironmentVariable($Matches[1].Trim(), $Matches[2].Trim(), 'Process')
#     }
#   }
#
# As of this version of the pipeline, none of the data sources require a
# credential — both SteamSpy and Wikidata are open public APIs. This file
# is kept as a template for future use (e.g. switching to the Steam Web
# API, which requires a key).

# STEAM_API_KEY=your_steam_web_api_key_here
